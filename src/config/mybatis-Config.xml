<?xml version="1.0" encoding="euc-kr"?>
<!DOCTYPE configuration
PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
  <!-- JDBC ???쇱?대? ??蹂? 諛? ?곗?댄?곕??댁?? ?곌껐??蹂? -->
  <environments default="development">
    <environment id="development">
      <transactionManager type="JDBC"/>
      <dataSource type="POOLED">
        <property name="driver" value="oracle.jdbc.OracleDriver"/>
        <property name="url" value="jdbc:oracle:thin:@127.0.0.1:1521:XE"/>
        <property name="username" value="hr"/>
        <property name="password" value="hr"/>
      </dataSource>
    </environment>
  </environments>
  
  <mappers>

    <mapper resource="config/couponMapper.xml"/>
    <mapper resource="config/memberMapper.xml"/>
    <mapper resource="config/myPointHistoryMapper.xml"/>
    <mapper resource="config/myAssetMapper.xml"/>
    <mapper resource="config/newsMapper.xml"/>
    <mapper resource="config/StockListMapper.xml"/>
    <mapper resource="config/stockDetailMapper.xml"/>
  </mappers>
  
</configuration>